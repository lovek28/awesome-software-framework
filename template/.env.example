# Copy to .env and fill in. Never commit .env.
# Use different values per environment (development / staging / production). See infra/README.md.

# --- development (localhost) ---
# Database (required for backend). Match stack.config.json and infra/README.md.
# Postgres (default docker-compose.yml):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app"
# MySQL (docker-compose.mysql.yml):
# DATABASE_URL="mysql://app:app@localhost:3306/app"
# SQLite (no Docker; file created by ORM):
# DATABASE_URL="file:./dev.db"

# API base URL (for frontend / server-side calls)
NEXT_PUBLIC_API_URL=http://localhost:3001
# or API_URL=http://localhost:3001

# --- staging / production: set DATABASE_URL, API_URL, and secrets per environment (e.g. in host or CI secrets) ---

# --- Secrets: set in .env only; never commit .env ---
# Auth (when stack.config.json has auth: jwt | nextauth | clerk, etc.):
# JWT_SECRET=          # min 32 chars for HS256
# AUTH_SECRET=         # NextAuth
# AUTH_CLIENT_SECRET=  # OAuth provider client secret
# API_KEY=             # External APIs
