# Copy to .env and fill in. Never commit .env.

# Database (required for backend). Match docker-compose.yml or your DB.
# Postgres (default):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app"

# API base URL (for frontend / server-side calls)
NEXT_PUBLIC_API_URL=http://localhost:3001
# or API_URL=http://localhost:3001

# Optional: auth, external APIs, etc.
# JWT_SECRET=
# API_KEY=
