# Copy to .env and fill in. Never commit .env.

# Database (required for backend). Match stack.config.json and infra/README.md.
# Postgres (default docker-compose.yml):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app"
# MySQL (docker-compose.mysql.yml):
# DATABASE_URL="mysql://app:app@localhost:3306/app"
# SQLite (no Docker; file created by ORM):
# DATABASE_URL="file:./dev.db"

# API base URL (for frontend / server-side calls)
NEXT_PUBLIC_API_URL=http://localhost:3001
# or API_URL=http://localhost:3001

# Optional: auth, external APIs, etc.
# JWT_SECRET=
# API_KEY=
