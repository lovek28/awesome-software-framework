{
  "pipeline": [
    "idea",
    "product_spec",
    "domain_rules",
    "ux_flow",
    "ui_system",
    "architecture",
    "backend",
    "frontend",
    "tests"
  ],
  "optional": ["tests"],
  "stages": {
    "idea": { "description": "Capture and clarify the user's idea." },
    "product_spec": { "description": "Write spec/product/spec.md (problem, users, features, requirements, constraints)." },
    "domain_rules": { "description": "Write spec/domain/entities.md, rules.md, glossary.md." },
    "ux_flow": { "description": "Write spec/ux/flows.md and spec/ux/states.md." },
    "ui_system": { "description": "Write spec/ui/system.md (components, design principles)." },
    "architecture": { "description": "Write spec/architecture/overview.md, backend.md, frontend.md, data-model.md." },
    "backend": { "description": "Implement in packages/domain, packages/services, apps/api." },
    "frontend": { "description": "Implement in packages/ui, apps/web." },
    "tests": { "description": "Implement in tests/unit, tests/integration, tests/e2e.", "optional": true }
  }
}
